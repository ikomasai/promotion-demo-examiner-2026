{
  "permissions": {
    "allow": [
      "Bash(gh issue create:*)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "supabase"
  ],
  "enabledPlugins": {
    "claude-mem@thedotmack": true
  },
  "deny": [
    "Bash(sudo:*)",
    "Read(env)",
    "Read(.env.*)",
    "Read(id_rsa)",
    "Read(id_ed25519)",
    "Read(**/*token*)",
    "Read(**/*key*)",
    "Write(.env*)",
    "Write(**/secrets/**)",
    "Bash(wget:*)",
    "Bash(nc:*)",
    "Bash(npm uninstall:*)",
    "Bash(npm remove:*)",
    "Bash(psql:*)",
    "Bash(mysql:*)",
    "Bash(mongod:*)"
  ]
}
