# ─── フロントエンド（Expo） ───
# 取得: Supabase Dashboard > Project Settings > API
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ─── Edge Functions（Supabase 自動注入） ───
# ※ SUPABASE_URL, SUPABASE_ANON_KEY, SUPABASE_SERVICE_ROLE_KEY は
#   Supabase Edge Functions 実行時に自動注入されるため設定不要。
#   ローカルテスト (supabase functions serve) でも .env.local から自動読み込み。

# ─── Google Drive API ───
# 取得: GCP Console > IAM > Service Accounts > Keys > JSON
# JSON をそのまま1行で貼り付ける（改行を \n にエスケープ）
GOOGLE_DRIVE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
# 取得: Google Drive でルートフォルダを作成し、URL末尾の ID をコピー
GOOGLE_DRIVE_ROOT_FOLDER_ID=your-drive-folder-id

# ─── Gemini API ───
# 取得: Google AI Studio (aistudio.google.com) > Get API Key
GEMINI_API_KEY=your-gemini-api-key

# ─── GitHub Actions（リポジトリ Secrets に設定） ───
# EXPO_PUBLIC_SUPABASE_URL      → Settings > Secrets > Actions
# EXPO_PUBLIC_SUPABASE_ANON_KEY → Settings > Secrets > Actions
